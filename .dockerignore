# Exclude Node.js files
**/node_modules
**/.next
**/out
**/build
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Exclude Python virtual environments & build files
**/venv
**/.venv
**/env
**/.env
**/.pytest_cache
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.ipynb_checkpoints

# Exclude database files
**/pgdata

# Exclude source control files & IDE files
.git
.gitignore
.dockerignore
.vscode
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

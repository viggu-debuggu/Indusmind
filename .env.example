# Application Environment
ENVIRONMENT=development
PORT=8000
SECRET_KEY=your-super-secret-key-change-in-production-123456 # WARNING: Never reuse this example secret key in production! Always generate a unique, cryptographically secure key.

# Database Settings
DATABASE_URL=postgresql://indusmind_user:indusmind_password@localhost:5432/indusmind_db

# Storage Provider Configuration (local, s3, azure, minio)
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=/app/storage

# AWS S3 Settings (Required if STORAGE_PROVIDER=s3)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_BUCKET_NAME=your_bucket_name
# AWS_REGION=us-east-1

# Azure Blob Settings (Required if STORAGE_PROVIDER=azure)
# AZURE_CONNECTION_STRING=your_azure_connection_string
# AZURE_CONTAINER_NAME=your_container_name

# MinIO Settings (Required if STORAGE_PROVIDER=minio)
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minio_user
# MINIO_SECRET_KEY=minio_password
# MINIO_BUCKET=indusmind-bucket

# AI RAG & LLM Settings
LLM_PROVIDER=ollama
# OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
# AZURE_OPENAI_API_KEY=your_azure_key
# AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

